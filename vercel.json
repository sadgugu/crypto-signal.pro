{
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "Content-Security-Policy",
          "value": "default-src *; script-src * 'unsafe-inline' 'unsafe-eval'; style-src * 'unsafe-inline'; img-src * data: blob:; connect-src *; font-src *; frame-src *;"
        }
      ]
    }
  ],
  "rewrites": [
    {
      "source": "/api/klines",
      "destination": "https://api.binance.com/api/v3/klines"
    },
    {
      "source": "/api/ticker",
      "destination": "https://api.binance.com/api/v3/ticker/24hr"
    }
  ]
}
